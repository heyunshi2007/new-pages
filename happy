  <!-- ========== JS ========== -->
  <script>
    // Number line
    (function() {
      var colors = ['orange','blue','green','gold','purple','pink'];
      var line = document.getElementById('numberLine');
      if (!line) return;
      for (var i = 0; i <= 20; i++) {
        var node = document.createElement('div');
        node.className = 'num-node';
        node.innerHTML = '<div class="num-circle ' + colors[i % colors.length] + '">' + i + '</div>';
        line.appendChild(node);
        if (i < 20) {
          var bar = document.createElement('div');
          bar.className = 'num-line-bar';
          line.appendChild(bar);
        }
      }
    })();

    // Check items toggle
    function toggleCheck(el) {
      el.classList.toggle('checked');
      saveChecks();
    }

    function saveChecks() {
      var items = document.querySelectorAll('.check-item');
      var states = [];
      items.forEach(function(item, i) {
        states.push(item.classList.contains('checked') ? 1 : 0);
      });
      try { localStorage.setItem('grade1-checks', JSON.stringify(states)); } catch(e) {}
    }

    function loadChecks() {
      try {
        var data = localStorage.getItem('grade1-checks');
        if (!data) return;
        var states = JSON.parse(data);
        var items = document.querySelectorAll('.check-item');
        states.forEach(function(s, i) {
          if (s && items[i]) items[i].classList.add('checked');
        });
      } catch(e) {}
    }
    loadChecks();

    // Smooth nav highlight
    (function() {
      var links = document.querySelectorAll('.nav-link');
      var sections = [];
      links.forEach(function(link) {
        var id = link.getAttribute('href').substring(1);
        var el = document.getElementById(id);
        if (el) sections.push({ link: link, el: el });
      });

      function update() {
        var scroll = window.scrollY + 80;
        sections.forEach(function(s) {
          var top = s.el.offsetTop;
          var bottom = top + s.el.offsetHeight;
          if (scroll >= top && scroll < bottom) {
            links.forEach(function(l) { l.classList.remove('active'); });
            s.link.classList.add('active');
          }
        });
      }
      window.addEventListener('scroll', update);
      update();
    })();
  </script>

