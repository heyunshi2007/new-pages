    }
    .py-letter {
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      border: 2px solid var(--rule);
      border-radius: 10px;
      font-family: var(--font-body);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--ink);
      transition: all 0.15s;
      cursor: default;
      position: relative;
    }
    .py-letter:hover {
      border-color: var(--accent);
      background: #FFF3E0;
      transform: scale(1.1);
    }
    .py-letter .tip {
      display: none;
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--ink);
      color: #fff;
      padding: 0.3rem 0.6rem;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 400;
      white-space: nowrap;
      font-family: var(--font-cn);
      z-index: 10;
    }
    .py-letter:hover .tip { display: block; }
    .py-letter .tip::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: var(--ink);
    }

    /* ============ TONE MARKS ============ */
    .tone-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.6rem;
      margin-top: 1rem;
    }
    .tone-card {
      background: #fff;
      border: 2px solid var(--rule);
      border-radius: 12px;
      padding: 0.8rem;
      text-align: center;
      transition: all 0.15s;
    }
    .tone-card:hover {
      border-color: var(--accent);
      background: #FFF8F0;
    }
    .tone-symbol {
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--accent);
      margin-bottom: 0.2rem;
    }
    .tone-name {
      font-size: 0.8rem;
      color: var(--muted);
      font-family: var(--font-cn);
    }
    .tone-desc {
      font-size: 0.75rem;
      color: #999;
      font-family: var(--font-cn);
    }

    /* ============ CHARACTER GRID ============ */
    .char-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
      gap: 0.6rem;
      margin-top: 1rem;
    }
    .char-item {
      width: 100%;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      border: 2px solid var(--rule);
      border-radius: 10px;
      font-family: var(--font-cn);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent);
      transition: all 0.15s;
      cursor: default;
    }
    .char-item:hover {
      border-color: var(--accent);
      background: #FFF3E0;
      transform: scale(1.05);
    }

    /* ============ MATH VISUAL ============ */
    .math-shapes {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 1rem;
      justify-content: center;
    }
    .shape-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .shape-svg {
      width: 70px;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .shape-name {
      font-family: var(--font-cn);
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--ink);
    }

    /* Number line */
    .number-line-wrap {
      margin-top: 1rem;
      overflow-x: auto;
    }
    .number-line {
      display: flex;
      align-items: center;
      gap: 0;
      min-width: 500px;
      padding: 1rem 0;
    }
    .num-node {
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
    }
    .num-circle {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
