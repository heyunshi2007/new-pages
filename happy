        <div class="py-section">
          <div class="py-group">
            <div class="py-group-title">第一组：b p m f</div>
            <div class="py-letters">
              <div class="py-letter">b<span class="tip">像广播喇叭：b-b-b</span></div>
              <div class="py-letter">p<span class="tip">像泼水瓢：p-p-p</span></div>
