    .num-circle.blue { background: linear-gradient(135deg, #5C6BC0, #7986CB); }
    .num-circle.green { background: linear-gradient(135deg, #00897B, #26A69A); }
    .num-circle.gold { background: linear-gradient(135deg, #FFB300, #FFCA28); }
    .num-circle.purple { background: linear-gradient(135deg, #AB47BC, #CE93D8); }
    .num-circle.pink { background: linear-gradient(135deg, #EC407A, #F48FB1); }
    .num-line-bar {
      width: 40px;
      height: 3px;
      background: var(--rule);
      flex-shrink: 0;
      margin-top: -10px;
    }

    /* ============ PROGRESS CARD ============ */
    .progress-section {
      margin-top: 2rem;
    }
    .progress-title {
      font-family: var(--font-cn);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .checklist {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 0.8rem;
    }
    .check-item {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      padding: 0.7rem 1rem;
      background: #fff;
      border-radius: 10px;
      border: 1px solid var(--rule);
      cursor: pointer;
      transition: all 0.2s;
      user-select: none;
      font-family: var(--font-cn);
      font-size: 0.9rem;
    }
    .check-item:hover { border-color: var(--accent2); }
    .check-item.checked {
      background: #E8F5E9;
      border-color: var(--accent2);
    }
    .check-item.checked .check-box {
      background: var(--accent2);
      border-color: var(--accent2);
    }
    .check-item.checked .check-box::after {
      content: '✓';
      color: #fff;
      font-size: 0.8rem;
      font-weight: 700;
    }
    .check-box {
      width: 22px;
      height: 22px;
      border: 2px solid var(--rule);
      border-radius: 6px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }
    .check-label { color: var(--ink); }

    /* ============ TIPS BOX ============ */
    .tip-box {
      background: linear-gradient(135deg, #FFF8E1, #FFF3E0);
      border-left: 4px solid var(--accent3);
      border-radius: 0 12px 12px 0;
      padding: 1.2rem 1.5rem;
      margin-top: 1rem;
      font-family: var(--font-cn);
      font-size: 0.9rem;
      color: #664D03;
      line-height: 1.8;
    }
    .tip-box strong { color: #E65100; }
    .tip-box-green {
      background: linear-gradient(135deg, #E8F5E9, #E0F2F1);
      border-left-color: var(--accent2);
      color: #1B5E20;
    }
    .tip-box-green strong { color: #00695C; }

    /* ============ WEEKLY PLAN ============ */
    .weekly-table-wrap {
      overflow-x: auto;
      margin-top: 1rem;
    }
    .weekly-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      min-width: 600px;
      font-family: var(--font-cn);
      font-size: 0.85rem;
    }
    .weekly-table th {
      background: var(--accent2);
      color: #fff;
      padding: 0.8rem;
      font-weight: 700;
      text-align: left;
    }
    .weekly-table th:first-child { border-radius: 10px 0 0 0; }
    .weekly-table th:last-child { border-radius: 0 10px 0 0; }
    .weekly-table td {
      padding: 0.7rem 0.8rem;
      border-bottom: 1px solid var(--rule);
      vertical-align: top;
      line-height: 1.6;
    }
    .weekly-table tr:hover td { background: #F1F8E9; }
    .weekly-table td:first-child {
      font-weight: 700;
      color: var(--accent2);
      white-space: nowrap;
      width: 70px;
    }
    .weekly-sub {
      display: inline-block;
      font-size: 0.75rem;
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      font-weight: 600;
      margin-right: 0.3rem;
      margin-bottom: 0.2rem;
    }
    .sub-cn { background: #FFF3E0; color: #E65100; }
    .sub-math { background: #E8EAF6; color: #283593; }
    .sub-habit { background: #E0F2F1; color: #00695C; }

    /* ============ FOOTER ============ */
    .site-footer {
      text-align: center;
      padding: 2rem 1rem;
      color: var(--muted);
      font-size: 0.85rem;
      font-family: var(--font-cn);
      border-top: 1px solid var(--rule);
      margin-top: 2rem;
    }

    /* ============ RESPONSIVE ============ */
    @media (max-width: 768px) {
      .hero { padding: 2.5rem 1rem 2rem; }
      .hero h1 { font-size: 1.8rem; }
      article.page { padding: 1.2rem 1rem; }
      .card { padding: 1.2rem; }
      .tone-grid { grid-template-columns: repeat(2, 1fr); }
      .checklist { grid-template-columns: 1fr; }
      .char-grid { grid-template-columns: repeat(auto-fill, minmax(50px, 1fr)); }
    }

    @media (max-width: 480px) {
      .nav-link { padding: 0.7rem 1rem; font-size: 0.85rem; }
      .py-letter { width: 38px; height: 38px; font-size: 1rem; }
    }
  </style>
</head>
